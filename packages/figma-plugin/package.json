{
  "name": "click-ship-figma-plugin",
  "version": "1.0.0",
  "description": "Click-Ship Figma Plugin - Apply Figma styles to code via PRs",
  "main": "dist/code.js",
  "scripts": {
    "build": "npm run build:ui && npm run build:code",
    "build:ui": "esbuild src/ui.ts --bundle --outfile=dist/ui.js && node scripts/build-ui.js",
    "build:code": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2020",
    "watch": "concurrently \"npm run watch:ui\" \"npm run watch:code\"",
    "watch:ui": "esbuild src/ui.ts --bundle --outfile=dist/ui.js --watch",
    "watch:code": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2020 --watch",
    "dev": "npm run watch"
  },
  "keywords": ["figma", "plugin", "design-to-code", "click-ship"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@figma/plugin-typings": "^1.90.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
