# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-3.5-turbo
AI_SERVICE=openai

# GitHub OAuth Configuration
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: https://<your-extension-id>.chromiumapp.org/oauth2
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Authorization
# Comma-separated list of GitHub usernames allowed to use Click-Ship
ALLOWED_USERS=username1,username2,username3

# Server Configuration
PORT=8080

# Optional: Hugging Face (not currently used)
HF_TOKEN=your_hugging_face_token
