# ===========================================
# Click-Ship Cloud Configuration
# ===========================================

# Server Configuration
PORT=8080
NODE_ENV=development
API_URL=http://localhost:8080
APP_URL=http://localhost:3000

# ===========================================
# Supabase (Database)
# ===========================================
# Create project at: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ===========================================
# GitHub App Configuration
# ===========================================
# Create a GitHub App at: https://github.com/settings/apps
#
# Required Permissions:
# - Contents: Read & Write
# - Pull requests: Read & Write
# - Metadata: Read-only
#
# Webhook URL: https://api.click-ship.dev/webhooks/github
# Callback URL: https://api.click-ship.dev/auth/github/callback

GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# GitHub OAuth (for user authentication)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ===========================================
# OpenAI Configuration
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4-turbo-preview

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=your_random_secret_key_at_least_32_chars
JWT_EXPIRES_IN=7d

# ===========================================
# Slack Integration (Optional)
# ===========================================
# Create a Slack App at: https://api.slack.com/apps
#
# Bot Token Scopes:
# - chat:write
# - commands
# - incoming-webhook
#
# Slash Commands:
# - /click-ship

SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# ===========================================
# Linear Integration (Optional)
# ===========================================
# Create Linear OAuth at: https://linear.app/settings/api
LINEAR_CLIENT_ID=your_linear_client_id
LINEAR_CLIENT_SECRET=your_linear_client_secret
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret

# ===========================================
# Local Development (Legacy)
# ===========================================
# For local development without cloud services
# Comma-separated list of GitHub usernames allowed to use Click-Ship
ALLOWED_USERS=username1,username2,username3

# Optional: Hugging Face (not currently used)
HF_TOKEN=your_hugging_face_token
